+                    and str(out["gateway_port_status"]).strip().lower() == "busy"
+                    and str(out["service_status"]).strip().lower() in {"stopped", "ready"}
+                )
 
     dns_diag = out.get("dns") if isinstance(out.get("dns"), dict) else {}
