+def _recover_dashboard_like(
+    *,
+    ensure_live_watcher: bool,
+    dashboard_port: int,
+    db_path: Path,
+    watcher_tickers: str,
+    watcher_cycles: int,
+    watcher_sleep_seconds: int,
+) -> dict[str, Any]:
+    label = "watcher" if ensure_live_watcher else "dashboard"
+    started_at = _utc_now_iso()
