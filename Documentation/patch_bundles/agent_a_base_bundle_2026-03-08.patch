+
+    captured: list[tuple[str, list[str]]] = []
+
+    def fake_run_check(name, cmd, timeout_seconds, **kwargs):
+        del timeout_seconds, kwargs
+        captured.append((str(name), list(cmd)))
+        return {
+            "name": str(name),
+            "ok": True,
+            "returncode": 0,
+            "duration_seconds": 0.0,
+            "command": " ".join(cmd),
+            "stdout": "",
