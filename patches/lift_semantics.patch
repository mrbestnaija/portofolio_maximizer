+            SELECT
+                {id_expr} AS trade_id,
+                {run_expr} AS run_id,
+                {ts_expr} AS cycle_ts
+            FROM trade_executions
+            {where_sql}
+            ORDER BY cycle_ts DESC, trade_id DESC
+            LIMIT 1
+            """,
+            tuple(params),
+        ).fetchone()
